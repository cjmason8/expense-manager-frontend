# Cognito (required for login)
# Local dev: copy to .env.local
# Production: .env.production (committed) + optional GitLab CI build-args in frontend-deploy
VITE_COGNITO_REGION=ap-southeast-2
VITE_COGNITO_USER_POOL_ID=ap-southeast-2_qDA8JIm05
VITE_COGNITO_CLIENT_ID=your-spa-app-client-id
# Never use http:// here if the site is served over https:// — browsers will block it (mixed content).
# Examples:
#   (omit or leave empty) → https://your-domain.com/search, /week, …
#   VITE_API_BASE_URL=https://api.your-domain.com
#
# VITE_API_BASE_URL=
