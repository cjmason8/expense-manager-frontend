# Optional. Defaults to same-origin root (paths like /search, /week — proxy these in nginx to your API).
# Never use http:// here if the site is served over https:// — browsers will block it (mixed content).
# Examples:
#   (omit or leave empty) → https://your-domain.com/search, /week, …
#   VITE_API_BASE_URL=https://api.your-domain.com
#
# VITE_API_BASE_URL=
